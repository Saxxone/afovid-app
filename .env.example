# Client-visible vars must use EXPO_PUBLIC_ (see https://docs.expo.dev/guides/environment-variables/)

# REST root including Nest global prefix /api.
# On a physical device, `localhost` would point at the phone — use your computer's LAN IP, or leave
# localhost and rely on dev auto-rewrite: `envPublic.ts` replaces localhost with Metro's host IP when available.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api

# Socket.IO origin (same host as API; no trailing slash).
EXPO_PUBLIC_WS_URL=http://localhost:3000

# Android emulator without env: defaults to http://10.0.2.2:3000 (host machine).
